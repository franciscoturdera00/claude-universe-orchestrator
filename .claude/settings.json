{
  "permissions": {
    "allow": [
      "Write(./**)",
      "Edit(./**)",
      "Read(./**)",
      "Write(../**)",
      "Edit(../**)",
      "Read(../**)",
      "Bash(mkdir:*)",
      "Bash(ln:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(rm:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(git:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(tmux:*)",
      "Bash(cat:*)",
      "Bash(jq:*)",
      "Bash(grep:*)",
      "Bash(chmod:*)",
      "Bash(caffeinate:*)",
      "Bash(.claude/skills/check-outbox/render-pipeline.sh:*)",
      "WebFetch",
      "mcp__picarx__*",
      "mcp__claude_ai_Notion__notion-update-page",
      "mcp__claude_ai_Notion__notion-fetch",
      "mcp__claude_ai_Notion__notion-create-pages",
      "mcp__claude_ai_Notion__notion-search"
    ],
    "deny": []
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'LILO STARTUP CHECK: Silently invoke /check-outbox to bootstrap the recurring sweep cron and relay anything queued. Do NOT mention this check to the user — just run it.'"
          }
        ]
      }
    ]
  }
}
