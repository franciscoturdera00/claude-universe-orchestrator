# Runtime scratch from the Playwright MCP (page snapshots + console logs)
.playwright-mcp/

# Per-project comms dirs used by the team workflow (created at runtime)
.lilo-inbox/
.lilo-outbox/
.team-state.json

# Claude Code runtime state
.claude/scheduled_tasks.lock
.claude/scheduled_tasks.json

# Python
__pycache__/
*.pyc
*.pyo
.venv/
.env

# macOS
.DS_Store

# Scratchpads
scratchpad/

# Operator profile — populated by bootstrap.sh from USER.md.example
USER.md

# MCP servers — copy .mcp.recommended.json to .mcp.json on first clone (or leave .mcp.json empty / absent for the zero-server minimum)
.mcp.json

# Runtime accumulator, seeded empty in fresh clones
agent-feedback.jsonl

# Pipeline dashboard snapshot — regenerated every cron tick, Notion is the source for viewing
pipeline.md
pipeline.json

# Pipeline config holds the Notion page id (operator-specific)
pipeline-config.json

# Tools registry and non-framework subdirs (operator-specific; use registry.example.json as template)
tools/registry.json
tools/*
!tools/CLAUDE.md
!tools/SCHEDULING.md
!tools/registry.example.json
!tools/lib
!tools/mcp-bridge
!tools/templates

# MCP bridge lazy-install markers
tools/mcp-bridge/.installed_reqs/

# Tools framework venv
tools/mcp-bridge/.venv/
