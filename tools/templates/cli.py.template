"""
CLI adapter template for a claude_universe tool.

This template demonstrates how to structure a CLI that wraps tool functions
and outputs ToolResult JSON to stdout.
"""

import argparse
import sys
from pathlib import Path

# Add tools/lib to sys.path so tool_base can be imported. The tool's adapter
# is typically symlinked into orchestrator/tools/<name>/, so walk up from the
# real path to find tools/lib under the new or legacy layout.
_this = Path(__file__).resolve()
for _candidate in (
    _this.parents[2] / "tools" / "lib",
    _this.parents[2] / "orchestrator" / "tools" / "lib",
):
    if _candidate.exists():
        sys.path.insert(0, str(_candidate))
        break

from tool_base import run_tool, setup_logging

# Import adapters module (assumed to be in the same directory as this CLI).
import adapters.mcp as mcp_adapters

logger = setup_logging("cli")


