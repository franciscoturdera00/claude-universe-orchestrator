def doctor() -> ToolResult:
    """
    REQUIRED self-check. Every tool adapter must implement this.

    Verify that the tool's runtime prerequisites are satisfied:
    - External binaries in PATH (CLI tools, rendering engines, etc.)
    - API auth or credentials resolvable from env / config
    - Required data files present and parseable (master configs, templates)
    - Python imports succeed (heavy deps like playwright, python-docx, etc.)

    Return ToolResult.success=True only if every check passes. On failure,
    set success=False, put a list of failed checks in data["failed"], and use
    alerts[] for anything Lilo should surface to the operator (e.g., "claude
    CLI not logged in — pipeline will fail on next run").

    Expected structure of data on success:
        {"checks": [{"name": "claude-cli-present", "ok": true, "detail": "..."}]}

    doctor() is invoked on demand by Lilo and may be scheduled periodically.
    Keep it FAST (<5 seconds) and side-effect-free — no disk writes, no
    network calls beyond what's strictly needed to verify auth.
    """
    checks = []
    failed = []
    alerts = []

    # TODO: add real checks for this tool. Example patterns:
    #
    # import shutil
    # if shutil.which("some-binary"):
    #     checks.append({"name": "some-binary-present", "ok": True, "detail": shutil.which("some-binary")})
    # else:
    #     checks.append({"name": "some-binary-present", "ok": False, "detail": "not in PATH"})
    #     failed.append("some-binary-present")
    #     alerts.append("some-binary is not installed — tool will fail")

    success = len(failed) == 0
    return ToolResult(
        success=success,
        data={"checks": checks, "failed": failed},
        message=f"{len(checks) - len(failed)}/{len(checks)} checks passed" if checks else "no checks implemented",
        alerts=alerts,
    )
