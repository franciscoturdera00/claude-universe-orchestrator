"""
MCP adapter template for a claude_universe tool.

This template demonstrates how to structure tool functions that return ToolResult
and can be dynamically registered with the MCP bridge.
"""

import sys
from pathlib import Path

# Add tools/lib to sys.path so ToolResult can be imported when running via CLI.
# When loaded via the MCP bridge, the bridge already injects tools/lib — this
# block is for the CLI path only. The tool project is typically symlinked into
# orchestrator/tools/<name>, so walk up from the real adapter location to find
# the lib dir.
_this = Path(__file__).resolve()
for _candidate in (
    _this.parents[2] / "tools" / "lib",             # tool under orchestrator/tools/<name>/adapters/mcp.py
    _this.parents[2] / "orchestrator" / "tools" / "lib",  # tool sibling of orchestrator
):
    if _candidate.exists():
        sys.path.insert(0, str(_candidate))
        break

from tool_base import ToolResult


def example_action(param1: str, param2: int = 10) -> ToolResult:
    """
    Example tool action.

    Args:
        param1: A string parameter.
        param2: An optional integer parameter (default 10).

    Returns:
        A ToolResult containing the action outcome.
    """
    try:
        result_data = {
            "param1": param1,
            "param2": param2,
            "processed": True,
        }
        return ToolResult(
            success=True,
            data=result_data,
            message="Action completed successfully",
        )
    except Exception as e:
        return ToolResult(
            success=False,
            data={},
            message=f"Error: {e}",
        )


